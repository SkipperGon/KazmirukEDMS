@page
@model KazmirukEDMS.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Документы";
}

<div class="documents-header d-flex justify-content-between align-items-start">
    <div>
        <h1>📁 Документы</h1>
        <p>@Model.Paged.TotalCount документов в системе</p>
    </div>
    <a asp-page="Create" class="btn btn-primary" style="border-radius: 8px; padding: 0.5rem 1.5rem;">
        <span>➕ Создать документ</span>
    </a>
</div>

@if(Model.Cards.Count == 0)
{
    <div class="alert alert-info text-center py-5">
        <h4>Нет документов</h4>
        <p>Начните с создания первого документа</p>
    </div>
}
else
{
    <div class="document-list">
    @foreach(var c in Model.Cards)
    {
        <div class="document-row">
            <div class="card-inner">
                <div class="d-flex align-items-center" style="gap:1rem; width:100%">
                    <div style="flex:0 0 auto">
                        <img src="@c.IconUrl" alt="icon" class="doc-icon-small" />
                    </div>
                    <div class="doc-info" style="flex:1 1 auto; min-width:0">
                        <h5 class="card-title" title="@c.Title">@c.Title</h5>
                        <div class="meta-row">
                            @if(!string.IsNullOrEmpty(c.RegistrationNumber))
                            {
                                <span class="meta-item">
                                    <span class="meta-label">Рег.:</span>
                                    <span>@c.RegistrationNumber</span>
                                </span>
                            }
                            <span class="meta-item">
                                <span class="meta-label">Создан:</span>
                                <span>@c.CreatedAt.ToLocalTime().ToString("d")</span>
                            </span>
                        </div>
                    </div>
                    <div style="flex:0 0 auto; text-align:right">
                        <div class="mb-2">
                            <span class="badge @(c.Status == KazmirukEDMS.Models.DocumentStatus.Approved ? "bg-success" : c.Status == KazmirukEDMS.Models.DocumentStatus.UnderReview ? "bg-warning text-dark" : "bg-secondary")">
                                @c.Status
                            </span>
                        </div>
                        <div class="actions">
                            <a asp-page="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Открыть</a>
                            <a asp-page="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">Изменить</a>
                            <form method="post" asp-page="Delete" asp-route-id="@c.Id" onsubmit="return confirm('Удалить документ?');" class="d-inline" style="display:inline-block; margin-left:6px">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    </div>

    @if(Model.Paged.TotalCount > Model.Paged.PageSize)
    {
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= Math.Ceiling((double)Model.Paged.TotalCount / Model.Paged.PageSize); i++)
                {
                    <li class="page-item @(i == Model.Paged.Page ? "active" : "")">
                        <a class="page-link" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
